        <mxCell id="e_gold_streamlit" value="Redshift Data API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#545B64;fontColor=#545B64;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1" source="gold" target="streamlit">
