        <!-- Streamlit (non-AWS reporting) -->
        <mxCell id="streamlit" value="Streamlit&#10;dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#FF4B4B;fontColor=#C1272D;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1370" y="290" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- ===================== Edges ===================== -->
        <mxCell id="e_drive_lambda" value="classify + MD5 dedup" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#545B64;fontColor=#545B64;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1" source="drive" target="lambda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_secrets_lambda" value="creds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#879196;fontColor=#879196;fontSize=10;endArrow=open;endFill=0;" edge="1" parent="1" source="secrets" target="lambda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lambda_dynamo" value="read / write status" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#879196;fontColor=#879196;fontSize=10;endArrow=open;endFill=0;" edge="1" parent="1" source="lambda" target="dynamodb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lambda_s3" value="upload (Bronze)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#545B64;fontColor=#545B64;fontSize=10;endArrow=block;endFill=1;" edge="1" parent="1" source="lambda" target="s3">
          <mxGeometry relative="1" as="geometry" />
