<mxfile host="app.diagrams.net" type="device">
  <diagram id="healthcare-metrics-arch" name="Healthcare Metrics Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== Title ===================== -->
        <mxCell id="title" value="Healthcare Metrics — Event-Driven Data Platform (Bronze → Silver → Gold)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ===================== Phase groupings (background) ===================== -->
        <mxCell id="grpIngest" value="Ingestion  ·  Bronze → Silver" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8E9;strokeColor=#7AA116;dashed=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontColor=#5B7A10;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="90" width="620" height="470" as="geometry" />
        </mxCell>
        <mxCell id="grpGold" value="Gold refresh  ·  Silver → Gold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6EEFB;strokeColor=#8C4FFF;dashed=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontColor=#6B2FB5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="90" width="470" height="470" as="geometry" />
        </mxCell>

        <!-- ===================== Nodes ===================== -->
        <!-- Google Drive (non-AWS source) -->
        <mxCell id="drive" value="Google Drive&#10;(monthly CSVs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4285F4;fontColor=#1A73E8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- AWS Lambda -->
        <mxCell id="lambda" value="AWS Lambda&#10;Drive → S3" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" vertex="1" parent="1">
          <mxGeometry x="220" y="290" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Secrets Manager -->
        <mxCell id="secrets" value="Secrets Manager&#10;(Drive creds)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.secrets_manager;" vertex="1" parent="1">
          <mxGeometry x="220" y="130" width="60" height="60" as="geometry" />
