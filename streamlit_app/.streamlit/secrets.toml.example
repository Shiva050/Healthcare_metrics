# Copy to secrets.toml and adjust. All optional — the app falls back to these
# same values (the known pipeline infra) if unset. Credentials themselves come
# from the standard AWS chain (env vars, ~/.aws, or an attached IAM role), NOT
# from this file.

AWS_REGION           = "us-east-1"
REDSHIFT_WORKGROUP   = "default-workgroup"
REDSHIFT_DATABASE    = "healthcare_metrics"
REDSHIFT_SECRET_ARN  = "arn:aws:secretsmanager:us-east-1:995679261492:secret:redshift!default-namespace-admin-gONVpo"
